PORT=8080
HOST=0.0.0.0

# JWT
JWT_SECRET=change-me-to-a-long-random-secret-key-in-production
JWT_EXPIRY=2h

# File storage root (all user files live here)
FILES_ROOT=./uploads

# MongoDB Connection URI
MONGODB_URI=mongodb://localhost:27017/filebrowser

# AWS S3 Configuration
AWS_ACCESS_KEY_ID=your-access-key-id
AWS_SECRET_ACCESS_KEY=your-secret-access-key
AWS_REGION=us-east-1
S3_BUCKET_NAME=your-s3-bucket-name

# Max upload size (bytes) — default 10 GB
MAX_UPLOAD_SIZE=10737418240

# Enable thumbnails (requires sharp)
ENABLE_THUMBNAILS=true

# Base URL prefix (leave empty or set e.g. /files)
BASE_URL=

# Allow public signup
ALLOW_SIGNUP=false

# Min password length
MIN_PASSWORD_LENGTH=8

# CORS origin (* or specific origin)
CORS_ORIGIN=*
